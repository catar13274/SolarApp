SOLARAPP_DB_URL=sqlite:///./data/solarapp.db

# Multitenant: true = one SQLite file per firm under SOLARAPP_TENANT_ROOT; API requires X-Solarapp-Tenant
# (frontend sends it from "Firma activă"). false = single legacy database (SOLARAPP_DB_URL).
SOLARAPP_MULTITENANT=false
SOLARAPP_REGISTRY_URL=sqlite:///./data/registry.db
SOLARAPP_TENANT_ROOT=./data/tenants

# One-time migration of legacy single DB into a tenant folder (run from backend/: python scripts/migrate_legacy_to_tenant.py --help)
# MIGRATE_TENANT_NAME=

# Label shown for materials/stock when SOLARAPP_MULTITENANT=false
SOLARAPP_LEGACY_COMPANY_LABEL=SolarApp

XML_PARSER_URL=http://localhost:5000
XML_PARSER_TOKEN=dev-token-12345
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Supplier billing block on project invoice PDFs (optional)
COMPANY_INVOICE_LEGAL_NAME=
COMPANY_INVOICE_TAX_ID=
COMPANY_INVOICE_REGISTRATION=
COMPANY_INVOICE_ADDRESS=
COMPANY_INVOICE_BANK_NAME=
COMPANY_INVOICE_IBAN=
COMPANY_INVOICE_PHONE=
COMPANY_INVOICE_EMAIL=

# SQLite backup/restore API (Dashboard). Required for GET /api/v1/admin/database/backup and POST .../restore
SOLARAPP_BACKUP_TOKEN=
